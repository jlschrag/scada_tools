# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_RELOAD=False
LOG_LEVEL=INFO

# Ignition Gateway Configuration
IGNITION_GATEWAY_URL=http://localhost:8088

# REQUIRED: Set your Ignition Gateway credentials
# DO NOT use these defaults in production!
IGNITION_USERNAME=admin
IGNITION_PASSWORD=password

IGNITION_VERIFY_SSL=False

# Tag Provider Configuration
TAG_PROVIDER=default
OPC_SERVER_NAME=Ignition OPC UA Server

# Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_EXTENSIONS=[".csv",".xlsx",".xls"]
